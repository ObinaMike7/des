## Local PostgreSQL mode
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory
ACCOUNTS_DB_NAME=inventory
PRODUCTS_DB_NAME=inventory

## Supabase PostgreSQL mode (optional)
## If DATABASE_URL is set, local DB_* host/user/password values are ignored.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# DB_NAME=postgres
# ACCOUNTS_DB_NAME=postgres
# PRODUCTS_DB_NAME=postgres

JWT_SECRET=change_this_in_production
PORT=5000

## Frontend (Vite)
## For local dev (Vite on :5173 + backend on :5000), leave this unset.
## For a single Vercel deploy where `/api/*` is served by Vercel Functions, set this to an empty string.
# VITE_API_BASE_URL=

## Supabase (required when using supabase-js from the frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
